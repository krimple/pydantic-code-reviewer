# Honeycomb / OpenTelemetry
HONEYCOMB_API_KEY=your-honeycomb-api-key
HONEYCOMB_API_ENDPOINT=https://api.honeycomb.io:443
OTEL_SERVICE_NAME=code-reviewer
# OTEL_EXPORTER_OTLP_ENDPOINT and OTEL_EXPORTER_OTLP_HEADERS are set
# programmatically in telemetry.py — do NOT set them here.

# Disable auto-configured metrics exporter
OTEL_METRICS_EXPORTER=none

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Telemetry flags
CLAUDE_CODE_ENABLE_TELEMETRY=true
AGENT_LOG_STATUS=true
OTEL_LOG_USER_PROMPTS=true
